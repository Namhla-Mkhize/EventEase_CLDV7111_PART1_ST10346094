<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EventEase</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EventEase.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark border-bottom box-shadow mb-3" style="background-color: #1a3a1a;">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index" style="color: #FFD700;">EventEase</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link fw-bold @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active-nav" : "")"
                               asp-area="" asp-controller="Home" asp-action="Index" style="color: #FFD700;">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-bold @(ViewContext.RouteData.Values["controller"]?.ToString() == "Venues" ? "active-nav" : "")"
                               asp-area="" asp-controller="Venues" asp-action="Index" style="color: #FFD700;">Venues</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-bold @(ViewContext.RouteData.Values["controller"]?.ToString() == "Events" ? "active-nav" : "")"
                               asp-area="" asp-controller="Events" asp-action="Index" style="color: #FFD700;">Events</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-bold @(ViewContext.RouteData.Values["controller"]?.ToString() == "Bookings" ? "active-nav" : "")"
                               asp-area="" asp-controller="Bookings" asp-action="Index" style="color: #FFD700;">Bookings</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - EventEase - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
