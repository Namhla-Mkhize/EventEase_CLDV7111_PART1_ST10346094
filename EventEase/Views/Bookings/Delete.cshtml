@model EventEase.Models.Booking

@{
    ViewData["Title"] = "Delete Booking";
}
<div class="container mt-4">
<h1>Are you sure you want to delete this booking?</h1>

<p><b>Booking ID:</b> @Model.BookingId</p>
<p><b>Venue:</b> @Model.Venue?.VenueName</p>
<p><b>Event:</b> @Model.Event?.EventName</p>
<p><b>Booking Date:</b> @Model.BookingDate.ToShortDateString()</p>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="BookingId" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form> 
 
</div>