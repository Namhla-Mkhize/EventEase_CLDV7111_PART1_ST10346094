@model EventEase.Models.Venue

@{
    ViewData["Title"] = "Delete Venue";
}
<div class="container mt-4">
<h1>Are you sure you want to delete this venue?</h1>

<p><b>Venue Name:</b> @Model.VenueName</p>
<p><b>Location:</b> @Model.Location</p>
<p><b>Capacity:</b> @Model.Capacity</p>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="VenueId" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form> 
</div>