@model EventEase.Models.Venue

@{
    ViewData["Title"] = "Venue Details";
}

<div class="container mt-4">
    <h1>@Model.VenueName</h1>
    <img src="@Model.ImageURL" alt="@Model.VenueName" class="img-fluid rounded mb-3" style="max-height:400px; width:100%; object-fit:cover;" />
    <p><b>Location:</b> @Model.Location</p>
    <p><b>Capacity:</b> @Model.Capacity</p>
    <a asp-action="Index" class="btn btn-secondary">Back to Venues</a>
    <a asp-action="Edit" asp-route-id="@Model.VenueId" class="btn btn-warning">Edit</a>
</div>